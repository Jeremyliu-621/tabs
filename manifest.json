{
  "manifest_version": 3,
  "name": "Tabs",
  "version": "0.1.0",
  "description": "Automatically learn which tabs belong together and switch between projects with one click.",
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}